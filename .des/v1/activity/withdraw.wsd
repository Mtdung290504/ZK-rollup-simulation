@startuml "Withdraw Flow (L2 -> L1 - Manual Claim)"
skinparam style strictuml

|User|
start
:Sign Withdraw TX (tx_type=2, embed l1_address);

|L2 Server|
:Validate Transaction (Target == Treasury);
:Update L2 State (Deduct Balance, Increase Nonce);
:Append to Transaction List;

|L2 Server|
:Group Transactions into Batch;
:Generate ZK Proof;

fork
  |L2 Server|
  :Submit Proof & Roots;
  |L1 Server|
  :Verify ZK Proof;
  :Store da_root in Batch History;
fork again
  |L2 Server|
  :Publish DA Blobs;
  |Archive Node|
  :Store DA Blobs;
end fork

|User|
:Fetch DA Blobs (from Archive Node);
:Rebuild DA Leaf (9-fields)\n& Generate Merkle Proof;
:Submit claimWithdrawal(tx_data, proof);

|L1 Server|
:Verify (msg.sender == l1_address);
:Verify (tx_type == 2);
:Verify (Receiver == Treasury);
:Check Nullifier (Poseidon(tx_hash));

if (Checks Passed & Nullifier Unused?) then (yes)
  if (Merkle Proof Valid against da_root?) then (yes)
    :Mark Nullifier;
    :Deduct Amount from Vault;
    :Transfer ETH to msg.sender;
  else (no)
    :Reject (Invalid Merkle Proof);
  endif
else (no)
  :Reject (Unauthorized / Double-spend);
endif

stop
@enduml